{
  "name": "mulmoterminal",
  "version": "1.7.1",
  "description": "MulmoTerminal — browser terminal + GUI panel for Claude Code. One command to start.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/receptron/mulmoterminal.git"
  },
  "keywords": [
    "claude",
    "claude-code",
    "terminal",
    "gui",
    "ai",
    "agent",
    "mulmoterminal"
  ],
  "bin": {
    "mulmoterminal": "bin/mulmoterminal.js",
    "claude-ollama": "bin/claude-ollama.js"
  },
  "files": [
    "bin/",
    "common/",
    "dist/",
    "server/",
    "plugins/",
    "Dockerfile.sandbox"
  ],
  "engines": {
    "node": ">=22.9"
  },
  "scripts": {
    "dev": "concurrently -n server,vite -c blue,green \"node scripts/dev-server.mjs\" \"vite\"",
    "dev:server": "node scripts/dev-server.mjs",
    "dev:client": "vite",
    "build": "vue-tsc -b && vite build",
    "typecheck": "vue-tsc -b",
    "typecheck:server": "tsc -p tsconfig.server.json",
    "typecheck:test": "vue-tsc -p tsconfig.test.json --noEmit && tsc -p tsconfig.test-server.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "preview": "vite preview",
    "server": "node --import tsx --env-file-if-exists=.env server/index.ts",
    "test": "vitest run",
    "prepack": "vue-tsc -b && vite build",
    "postinstall": "node server/fix-pty-perms.js"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@google/genai": "^2.13.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mulmobridge/web-push": "^0.2.0",
    "@mulmocast/deck-web": "^1.1.1",
    "@mulmocast/types": "^2.9.0",
    "@mulmochat-plugin/generate-image": "^1.1.0",
    "@mulmochat-plugin/ui-image": "^0.4.1",
    "@mulmoclaude/accounting-plugin": "^1.0.0",
    "@mulmoclaude/chart-plugin": "^1.0.0",
    "@mulmoclaude/collection-plugin": "^1.0.0",
    "@mulmoclaude/core": "^1.0.1",
    "@mulmoclaude/form-plugin": "^1.0.0",
    "@mulmoclaude/google-plugin": "^1.0.0",
    "@mulmoclaude/html-plugin": "^1.0.0",
    "@mulmoclaude/markdown-plugin": "^1.0.0",
    "@mulmoclaude/mulmoscript-plugin": "^1.0.0",
    "@mulmoclaude/x-plugin": "^0.1.2",
    "@receptron/task-scheduler": "^0.1.0",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.12",
    "echarts": "^6.0.0",
    "express": "^5.2.1",
    "firebase": "^12.16.0",
    "graphai": "^2.0.18",
    "gui-chat-protocol": "^1.2.0",
    "marked": "^18.0.7",
    "material-symbols": "^0.45.8",
    "mulmocast": "^2.9.0",
    "node-pty": "^1.1.0",
    "puppeteer": "^25.3.0",
    "sharp": "^0.35.3",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.23.1",
    "uqr": "^0.1.3",
    "vue": "^3.5.40",
    "vue-i18n": "^11.4.7",
    "vue-router": "^5.2.0",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.2.0",
    "eslint-plugin-vue": "^10.10.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "knip": "6.29.0",
    "prettier": "^3.9.6",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.0.12",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.8"
  }
}
